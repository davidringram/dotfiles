
# 1. Define Dotfiles Location
export ZSH_DOTS=$HOME/.dotfiles/zsh

# --- LOAD MODULES (The Smart Way) ---
# This automatically loads path, plugins, alias, functions, fun, and your new secrets!
if [ -d "$ZSH_DOTS" ]; then
  for file in "$ZSH_DOTS"/*.zsh; do
    source "$file"
  done
fi

